{
  "name": "railpoint",
  "version": "1.0.0",
  "description": "Recurring membership-billing service on the Nomba payment API, with a Smart Recovery engine.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:api": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed": "ts-node-dev --transpile-only src/scripts/seed.ts",
    "smoke:sandbox": "ts-node-dev --transpile-only src/scripts/smokeSandbox.ts",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "bullmq": "^5.13.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "5.10.1",
    "mongoose": "^8.7.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.4",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.2",
    "pino-pretty": "^11.2.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
