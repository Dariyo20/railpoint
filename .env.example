# ─── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
# Public base URL of THIS api (used to build Nomba callbackUrl). e.g. ngrok URL.
PUBLIC_BASE_URL=http://localhost:4000

# ─── MongoDB ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/railpoint

# ─── Redis (Upstash) ───────────────────────────────────────────────────────
# Upstash gives you a rediss:// URL. BullMQ needs TLS for Upstash.
REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@your-instance.upstash.io:6379

# ─── Nomba ─────────────────────────────────────────────────────────────────
# Set MOCK_NOMBA=true to run the entire system WITHOUT real Nomba credentials.
# The adapter then returns deterministic, sandbox-like responses so the whole
# demo (subscribe -> charge -> fail -> recover) works offline. Set to false to
# hit the real Nomba API.
MOCK_NOMBA=true

# Production base URL: https://api.nomba.com/v1
# Sandbox base URL:    https://sandbox.nomba.com/v1
NOMBA_BASE_URL=https://sandbox.nomba.com/v1
# Parent account id -> sent in the `accountId` header on every call.
NOMBA_ACCOUNT_ID=your-parent-account-id
# Sub-account collections are scoped to -> sent as order.accountId. Optional.
NOMBA_SUBACCOUNT_ID=your-sub-account-id
NOMBA_CLIENT_ID=your-client-id
NOMBA_CLIENT_SECRET=your-client-secret
# The signature key you configured on the Nomba dashboard Webhook Setup page.
NOMBA_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key
# If true, reject webhooks whose signature fails. Keep true in production.
WEBHOOK_VERIFY_SIGNATURE=true

# ─── Billing engine ────────────────────────────────────────────────────────
# How often the repeatable billing tick runs (ms). 60000 = 1 min for fast demos.
BILLING_TICK_MS=60000
# Recovery window in days from the cycle due date.
RECOVERY_WINDOW_DAYS=10
# Max number of recovery attempts before the virtual-account fallback.
MAX_RECOVERY_ATTEMPTS=4
# Floor for partial collection, as a fraction of the remaining balance (0-1).
PARTIAL_CHARGE_FRACTION=0.5
# Default payday day-of-month (1-28) when a member has no expectedPayday.
DEFAULT_PAYDAY=25
# When true, recovery retries fire seconds apart (not payday-aware) so the
# whole recovery arc is visible in under a minute during a live demo.
DEMO_FAST_RECOVERY=true
